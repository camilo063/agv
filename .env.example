# ============================================================================
# AGV Salud Animal — variables de entorno (plantilla)
# Copiar a `.env` y rellenar. NUNCA commitear `.env`. PAYLOAD_SECRET distinto por ambiente.
# ============================================================================

# --- Base de datos --------------------------------------------------------
# local: Postgres en Docker (ver docker-compose.yml). Misma major que Neon (PG 16).
# stage/prd: connection string POOLED de Neon (PgBouncer).
DATABASE_URI=postgres://agv:agv@localhost:5432/agv

# --- Payload --------------------------------------------------------------
# Cadena aleatoria larga; DISTINTA por ambiente. Generar: `openssl rand -hex 32`
PAYLOAD_SECRET=changeme-genera-uno-por-ambiente

# URL pública del sitio (usada por Payload para enlaces de correo, CORS, etc.)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# --- Storage de imágenes (portable por diseño — ver lib/storage.ts) -------
# Local: dejar VACÍO -> Payload escribe en ./uploads (disco).
# Stage/Prd en Vercel: definir el token -> se activa @payloadcms/storage-vercel-blob
#                     (clientUploads:true, evita el límite de 4.5 MB de Vercel).
BLOB_READ_WRITE_TOKEN=

# Futuro AWS/S3 (migración = config, no código). Ver bloque comentado en lib/storage.ts.
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT=

# --- Correo (TODO(D-6): AWS SES vs Resend — NO decidido) ------------------
# Sin configurar: Payload registra los correos en consola (modo dev). Ver lib/email.ts.
# Opción SES vía SMTP (nodemailer):
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM="AGV Salud Animal <no-reply@example.com>"
# Opción Resend:
# RESEND_API_KEY=

# --- Recordatorios (scheduler-agnóstico — ver endpoints/recordatorios.ts) -
# Secreto que protege el endpoint POST /api/recordatorios/run.
# En dev lo dispara Vercel Cron; en ECS lo dispararía EventBridge golpeando el mismo endpoint.
CRON_SECRET=changeme-cron-secret

# D-1 (CERRADO): estado "Próximo" ≤5 días; emails a 3 y 0 días.
AGV_DIAS_PROXIMO=5
AGV_DIAS_EMAIL=3,0
